{
  "name": "mountain",
  "version": "1.0.0",
  "description": "A simple game framework similar to MonoGame written in C++23.",
  "homepage": "https://github.com/BloodLantern/Mountain",
  "license": "zlib",
  "dependencies": [
    {
      "name": "freetype",
      "version>=": "2.13.3"
    },
    {
      "name": "openal-soft",
      "version>=": "1.24.3#1"
    },
    {
      "name": "imgui",
      "version>=": "1.91.9",
      "features": [
        "docking-experimental",
        "sdl3-binding",
        "opengl3-binding"
      ]
    },
    {
      "name": "magic-enum",
      "version>=": "0.9.7#1"
    },
    {
      "name": "minimp3",
      "version>=": "2021-11-30"
    },
    {
      "name": "opengl",
      "version>=": "2022-12-04#3"
    },
    {
      "name": "sdl3",
      "version>=": "3.2.22"
    },
    {
      "name": "stb",
      "version>=": "2024-07-29#1"
    }
  ],
  "features": {
    "tests": {
      "description": "Build and perform Mountain unit tests",
      "dependencies": [
        "gtest"
      ]
    }
  }
}
