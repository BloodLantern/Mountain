{
  "name": "mountain",
  "version": "1.0.0",
  "description": "A simple game framework similar to MonoGame written in C++23.",
  "homepage": "https://github.com/BloodLantern/Mountain",
  "license": "zlib",
  "dependencies": [
    "opengl",
    "magic-enum",
    "minimp3",
    "sdl3",
    "stb",
    {
      "name": "freetype",
      "version>=": "2.13.3"
    },
    {
      "name": "openal-soft",
      "version>=": "1.24.3#1"
    },
    {
      "name": "imgui",
      "version>=": "1.91.9",
      "features": [
        "docking-experimental",
        "sdl3-binding",
        "opengl3-binding"
      ]
    }
  ],
  "features": {
    "tests": {
      "description": "Build and perform Mountain unit tests",
      "dependencies": [
        "gtest"
      ]
    }
  }
}
